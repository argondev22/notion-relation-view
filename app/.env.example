# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# =============================================================================
# Google OIDC Configuration
# =============================================================================
# Get your credentials from: https://console.cloud.google.com/
# 1. Create a new project or select existing one
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URI: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# =============================================================================
# Backend Configuration
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/app
REDIS_URL=redis://redis:6379/0

# JWT Configuration
# Generate a secure random key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=generate-a-random-secret-key-here-minimum-32-characters
JWT_EXPIRATION_HOURS=24
JWT_ALGORITHM=HS256

# Encryption Configuration
# Generate a secure random key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=generate-a-random-encryption-key-here-minimum-32-characters

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Application Settings
DEBUG=True

# =============================================================================
# Frontend Configuration
# =============================================================================
VITE_API_URL=http://localhost:8000
