# =============================================================================
# PostgreSQL Configuration (used by postgres service)
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=notion_relation_view

# =============================================================================
# Backend Configuration (used by backend service)
# =============================================================================

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/notion_relation_view

# Redis
REDIS_URL=redis://redis:6379

# JWT Authentication
JWT_SECRET=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Encryption (for Notion API tokens)
ENCRYPTION_KEY=dev-encryption-key-change-in-production

# CORS
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Frontend Configuration (used by frontend service)
# =============================================================================
VITE_API_URL=http://localhost:8000

# =============================================================================
# SECURITY WARNING
# =============================================================================
# IMPORTANT: Change JWT_SECRET and ENCRYPTION_KEY in production!
# Use strong, randomly generated values for production environments.
# =============================================================================
